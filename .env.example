
# AI Interview Prep - Environment Configuration
# Copy this file to .env and fill in your values

# ================================
# Required Variables
# ================================

# OpenAI API Key (required for AI functionality)
OPENAI_API_KEY=sk-your-openai-api-key-here

# ================================
# AWS Configuration
# ================================

# AWS Region (default: us-east-1)
AWS_REGION=us-east-1

# AWS Profile for local development (created by npm run aws:login)
AWS_PROFILE=terraform

# AWS Account ID (will be detected automatically if not set)
# AWS_ACCOUNT_ID=123456789012

# ================================
# Environment Settings
# ================================

# Deployment environment (development, staging, production)
ENVIRONMENT=development

# Application name (used for resource naming)
APP_NAME=ai-interview-prep

# ================================
# Development Settings
# ================================

# Enable debug logging
DEBUG=false

# Local development API URL (for frontend development)
# Leave empty to use the deployed API Gateway URL
LOCAL_API_URL=http://localhost:8080

# ================================
# Terraform Settings
# ================================

# Terraform workspace (optional, for multiple environments)
# TF_WORKSPACE=development

# Terraform backend configuration (optional)
# TF_BACKEND_BUCKET=your-terraform-state-bucket
# TF_BACKEND_KEY=ai-interview-prep/terraform.tfstate
# TF_BACKEND_REGION=us-east-1

# ================================
# Frontend Development
# ================================

# Vite development server port
VITE_PORT=5173

# API endpoint override for development
# VITE_API_ENDPOINT=https://your-api-gateway-url.amazonaws.com

# ================================
# Optional: CI/CD Configuration
# ================================

# These are typically set in GitHub Actions, not needed locally
# AWS_ACCESS_KEY_ID=your-access-key
# AWS_SECRET_ACCESS_KEY=your-secret-key

# ================================
# Optional: Advanced Settings
# ================================

# Lambda function timeout (seconds)
LAMBDA_TIMEOUT=120

# Lambda function memory (MB)
LAMBDA_MEMORY=1024

# Log retention period (days)
LOG_RETENTION_DAYS=14

# ================================
# Domain Configuration
# ================================

# Base domain name (the domain you own in Route 53)
DOMAIN_NAME=chrismarasco.io

# Subdomain for the application
SUBDOMAIN=ai-ip

# Whether to create Route 53 records and SSL certificates
# Set to false if you want to use API Gateway URLs only
CREATE_ROUTE53_RECORDS=true

# This will create:
# - Development: dev.ai-ip.chrismarasco.io
# - Production: ai-ip.chrismarasco.io