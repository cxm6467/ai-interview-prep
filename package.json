{
  "name": "ai-interview-prep-monorepo",
  "private": true,
  "version": "0.1.0",
  "description": "AI-powered interview preparation with strategic question generation, role-based coaching, and comprehensive skills analysis",
  "workspaces": [
    "apps/frontend",
    "apps/backend"
  ],
  "scripts": {
    "dev": "npm run dev --workspace=ai-interview-prep-frontend",
    "dev:frontend": "npm run dev --workspace=ai-interview-prep-frontend",
    "dev:backend": "npm run dev --workspace=ai-interview-prep-backend",
    "build": "npm run build --workspace=ai-interview-prep-frontend && npm run build --workspace=ai-interview-prep-backend",
    "build:frontend": "npm run build --workspace=ai-interview-prep-frontend",
    "build:backend": "npm run build --workspace=ai-interview-prep-backend",
    "lint": "npm run lint --workspace=ai-interview-prep-frontend",
    "lint:fix": "npm run lint:fix --workspace=ai-interview-prep-frontend",
    "setup:env": "./scripts/setup-env.sh",
    "setup:init": "./scripts/setup-env.sh init",
    "aws:login": "./scripts/aws-login.sh",
    "aws:quick-login": "./scripts/aws-browser-login.sh",
    "deploy": "./scripts/setup-env.sh export && cd iac && terraform apply",
    "deploy:dry-run": "./scripts/setup-env.sh export && npm run deploy:plan",
    "deploy:destroy": "./scripts/setup-env.sh export && cd iac && terraform destroy",
    "deploy:destroy:dry-run": "./scripts/setup-env.sh export && cd iac && terraform plan -destroy",
    "deploy:plan": "./scripts/setup-env.sh export && cd iac && terraform plan",
    "deploy:plan:detailed": "./scripts/setup-env.sh export && cd iac && terraform plan -detailed-exitcode",
    "deploy:dev": "ENVIRONMENT=development npm run deploy",
    "deploy:prod": "ENVIRONMENT=production npm run deploy",
    "deploy:local": "ENVIRONMENT=local npm run deploy",
    "docker:build": "./scripts/setup-env.sh export && cd iac && docker build -f Dockerfile ../apps/backend -t ${APP_NAME:-ai-interview-prep}-${ENVIRONMENT:-development}",
    "docker:deploy": "npm run docker:build && npm run deploy",
    "docker:deploy:dry-run": "npm run docker:build && npm run deploy:dry-run",
    "tf:init": "cd iac && terraform init",
    "tf:validate": "cd iac && terraform validate",
    "tf:format": "cd iac && terraform fmt",
    "tf:refresh": "./scripts/setup-env.sh export && cd iac && terraform refresh",
    "deploy:interactive": "./scripts/deploy-interactive.sh"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "commitizen": "^4.3.1",
    "cz-conventional-changelog": "^3.0.1",
    "husky": "^9.1.2",
    "lint-staged": "^16.1.5",
    "prettier": "^3.6.2"
  }
}
