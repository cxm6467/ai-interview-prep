#!/usr/bin/env sh
. "$(dirname -- "$0")/_/husky.sh"

# Stash unstaged changes to only check staged files
STASH_NAME="pre-commit-$(date +%s)"
git stash push --keep-index --include-untracked --message "$STASH_NAME"

# Run lint and type check on staged files
npm run lint && npm run type-check

# Capture the exit code
RESULT=$?

# Restore stashed changes if any were stashed
if [ "$(git stash list -1 --grep "$STASH_NAME")" ]; then
  git stash pop -q
fi

# Exit with the result of the lint/type-check
[ $RESULT -ne 0 ] && exit 1
exit 0
